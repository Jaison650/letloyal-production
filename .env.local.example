# ─── Database (VPS MySQL) ─────────────────────────────────────────────────────
DB_HOST=72.60.18.98
DB_PORT=3306
DB_USER=letloyal_user
DB_PASSWORD=
DB_NAME=letloyal_prod

# ─── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED in production. Use: openssl rand -hex 64
JWT_SECRET=
JWT_EXPIRY=7d
# REQUIRED in production. Must be DIFFERENT from JWT_SECRET.
# Use: openssl rand -hex 64
CUSTOMER_JWT_SECRET=

# ─── Public base URL ──────────────────────────────────────────────────────────
# Local:      http://localhost:3000
# Production: https://pilot.letloyal.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── QR token safety expiry ───────────────────────────────────────────────────
# How long (minutes) an unscanned QR stays active before hard-expiry
QR_SAFETY_EXPIRY_MINUTES=30

# ─── Cloudflare R2 (image uploads — added in M3) ─────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_MEDIA=letloyal-media
NEXT_PUBLIC_MEDIA_URL=

# ─── Email / SMTP (Brevo — added in M2) ──────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@letloyal.com
SMTP_FROM_NAME=LetLoyal
