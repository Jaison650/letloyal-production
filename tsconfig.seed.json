{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["db/**/*.ts", "src/lib/**/*.ts"],
  "ts-node": {
    "require": ["dotenv/config"]
  }
}
